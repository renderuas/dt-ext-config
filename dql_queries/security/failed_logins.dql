// Propósito: Lista intentos de login fallidos repetidos por usuario/IP en una ventana de 1 hora.
// Parámetros a reemplazar: ${TU_UMBRAL_INTENTOS}, {{ambiente}}
// Autor: <nombre> | Fecha: <YYYY-MM-DD>

fetch logs, from: -1h
| filter event.category == "authentication" and event.outcome == "failure"
| summarize attempts = count(), by: { user.name, client.ip }
| filter attempts >= ${TU_UMBRAL_INTENTOS}
| fields environment = "{{ambiente}}", user.name, client.ip, attempts
| sort attempts desc
